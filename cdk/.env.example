# Slack Configuration for CDK Deployment
# Copy this file to .env and fill in your values
# Get these from https://api.slack.com/apps

SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# GitHub Webhook Configuration
# Generate a secure random string for webhook verification
# Example: openssl rand -hex 32

GITHUB_WEBHOOK_SECRET=your-github-webhook-secret-here

# GitHub MCP Server Configuration (optional)
# Personal access token for GitHub API access via MCP server
# Create at: https://github.com/settings/tokens
# Required scopes: repo, workflow, admin:org (depending on usage)

GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here
